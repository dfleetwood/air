; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

config_version=5

[application]

config/name="Aerie"
config/description="Bird flight prototype: floating islands, day/night, seasons, wind."
run/main_scene="res://spirit.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900

[rendering]

; The froxel grid the volumetric fog marches. EVERY cell runs air_fog.gdshader, so
; this number is a multiplier on a fairly expensive shader — 112/192 was 2.4M
; cells and brought a GTX 1060 to its knees. 64/64 is 262k, nine times cheaper,
; and the dye is a soft smoky thing that cannot tell the difference.
environment/volumetric_fog/volume_size=64
environment/volumetric_fog/volume_depth=64
environment/volumetric_fog/use_filter=1
anti_aliasing/quality/msaa_3d=2

[shader_globals]

season={
"type": "float",
"value": 1.0
}
wind_dir={
"type": "vec3",
"value": Vector3(0.7, 0.0, 0.7)
}
wind_strength={
"type": "float",
"value": 1.0
}
